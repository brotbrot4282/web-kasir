generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Kategori {
  id        String   @id @default(uuid()) @db.Uuid
  nama      String   @unique
  menu      Menu[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("kategori")
}

model Menu {
  id         String          @id @default(uuid()) @db.Uuid
  nama       String
  harga      Int
  kategoriId String          @map("kategori_id") @db.Uuid
  kategori   Kategori        @relation(fields: [kategoriId], references: [id], onDelete: Cascade)
  gambar     String?
  stok       Int             @default(0)
  isTersedia Boolean         @default(true) @map("is_tersedia")
  variants   Json?            @default("[]")
  itemTransaksi ItemTransaksi[]
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@map("menu")
}

model Member {
  id        String   @id @default(uuid()) @db.Uuid
  noWa      String   @unique
  nama      String?
  poin      Int      @default(0)
  transaksi Transaksi[]
  rewardPoin RewardPoin[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("member")
}

model RewardPoin {
  id          String     @id @default(uuid()) @db.Uuid
  memberId    String     @map("member_id") @db.Uuid
  member      Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transaksiId String?    @map("transaksi_id") @db.Uuid
  transaksi   Transaksi? @relation(fields: [transaksiId], references: [id], onDelete: SetNull)
  poin        Int
  keterangan  String?
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("reward_poin")
}

model Transaksi {
  id            String          @id @default(uuid()) @db.Uuid
  publicId      String          @unique @default(uuid()) @map("public_id")
  noTransaksi   String          @unique @map("no_transaksi")
  totalHarga    Int             @map("total_harga")
  diskon        Int             @default(0)
  totalBayar    Int             @map("total_bayar")
  kembalian     Int             @default(0)
  metodeBayar   String          @default("CASH") @map("metode_bayar")
  poinDigunakan Int             @default(0) @map("poin_digunakan")
  totalPoin     Int             @default(0) @map("total_poin")
  noWa          String?         @map("no_wa")
  memberId      String?         @map("member_id") @db.Uuid
  member        Member?         @relation(fields: [memberId], references: [id])
  itemTransaksi   ItemTransaksi[]
  rewardPoin      RewardPoin[]
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@map("transaksi")
}

model ItemTransaksi {
  id          String    @id @default(uuid()) @db.Uuid
  transaksiId String    @map("transaksi_id") @db.Uuid
  transaksi   Transaksi @relation(fields: [transaksiId], references: [id], onDelete: Cascade)
  menuId      String    @map("menu_id") @db.Uuid
  menu        Menu      @relation(fields: [menuId], references: [id])
  namaMenu    String    @map("nama_menu")
  harga       Int
  jumlah      Int
  subtotal    Int
  variant     String?
  statusDapur StatusDapur @default(MENUNGGU) @map("status_dapur")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("item_transaksi")
}

enum Role {
  OWNER
  KASIR
  DAPUR
}

enum StatusDapur {
  MENUNGGU
  DIMASAK
  SIAP
}

enum Shift {
  SHIFT_1
  SHIFT_2
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique
  password  String
  nama      String
  role         Role           @default(OWNER)
  shift        Shift?
  dailyReports DailyReport[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Stok {
  id         String   @id @default(uuid()) @db.Uuid
  namaBahan  String   @map("nama_bahan")
  jumlah     Int
  satuan     String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("stok")
}

model DailyReport {
  id             String   @id @default(uuid()) @db.Uuid
  tanggal        DateTime
  shift          Shift
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id])
  uangAwal       Int      @default(0) @map("uang_awal")
  openedAt       DateTime @default(now()) @map("opened_at")
  catatan        String?  @map("catatan")
  totalMakanan   Int      @default(0) @map("total_makanan")
  totalMinuman   Int      @default(0) @map("total_minuman")
  totalOmset     Int      @default(0) @map("total_omset")
  totalTransaksi Int      @default(0) @map("total_transaksi")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([tanggal, shift])
  @@map("daily_report")
}

model PengaturanPoin {
  id                Int      @id @default(1)
  rupiahPerPoin     Int      @default(15000) @map("rupiah_per_poin")
  poinPerGratisItem Int      @default(5) @map("poin_per_gratis_item")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("pengaturan_poin")
}
